{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ukk.school.local/protocol/v1/task.json",
  "title": "TASK Message",
  "description": "Task command message from relay to agent",
  "type": "object",
  "properties": {
    "type": { "const": "TASK" },
    "message_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique task identifier"
        },
        "task_type": {
          "type": "string",
          "enum": ["SCREENSHOT", "NET_POLICY", "PROCESS_POLICY", "CURSOR_CONTROL", "SCREEN_CONTROL", "TRAFFIC_LIMIT", "USB_POLICY", "AGENT_UPDATE", "GET_METRICS", "SHELL_EXEC"],
          "description": "Type of task to execute"
        },
        "payload": {
          "oneOf": [
            {
              "type": "object",
              "title": "ScreenshotPayload",
              "properties": {
                "quality": { "type": "integer", "minimum": 1, "maximum": 100, "default": 80 },
                "force_capture": { "type": "boolean", "default": false }
              }
            },
            {
              "type": "object",
              "title": "NetPolicyPayload",
              "properties": {
                "whitelist": { "type": "array", "items": { "type": "string" } },
                "blacklist": { "type": "array", "items": { "type": "string" } },
                "whitelist_only": { "type": "boolean" },
                "bandwidth_limit_kbps": { "type": "integer", "minimum": 0 }
              }
            },
            {
              "type": "object",
              "title": "ProcessPolicyPayload",
              "properties": {
                "blocked_processes": { "type": "array", "items": { "type": "string" } },
                "gpu_threshold_pct": { "type": "integer", "minimum": 0, "maximum": 100, "default": 40 },
                "gpu_check_duration_sec": { "type": "integer", "minimum": 0, "default": 30 },
                "auto_kill": { "type": "boolean", "default": false }
              }
            },
            {
              "type": "object",
              "title": "ScreenControlPayload",
              "properties": {
                "action": { "type": "string", "enum": ["BLACKOUT", "RESTORE", "DPMS_OFF", "DPMS_ON"] }
              },
              "required": ["action"]
            },
            {
              "type": "object",
              "title": "UsbPolicyPayload",
              "properties": {
                "blocked_classes": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 255 } },
                "block_mass_storage": { "type": "boolean", "default": true }
              }
            },
            {
              "type": "object",
              "title": "TrafficLimitPayload",
              "properties": {
                "target_domain": { "type": "string" },
                "limit_kbps": { "type": "integer", "minimum": 0 },
                "remove": { "type": "boolean", "default": false }
              }
            },
            {
              "type": "object",
              "title": "ShellExecPayload",
              "properties": {
                "command": { "type": "string" },
                "timeout_ms": { "type": "integer", "minimum": 0, "default": 30000 }
              },
              "required": ["command"]
            }
          ],
          "description": "Task-specific payload"
        },
        "priority": {
          "type": "string",
          "enum": ["NORMAL", "HIGH"],
          "default": "NORMAL",
          "description": "Task priority"
        },
        "deadline": {
          "type": "string",
          "format": "date-time",
          "description": "Task must complete by this time"
        }
      },
      "required": ["task_id", "task_type", "payload"]
    }
  },
  "required": ["type", "message_id", "timestamp", "payload"]
}
