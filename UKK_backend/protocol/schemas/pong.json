{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ukk.school.local/protocol/v1/pong.json",
  "title": "PONG Message",
  "description": "Response to PING message for connection health check",
  "type": "object",
  "properties": {
    "type": { "const": "PONG" },
    "message_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 0,
          "description": "Echo sequence number from PING"
        },
        "ping_sent_at": {
          "type": "string",
          "format": "date-time",
          "description": "Original PING timestamp"
        },
        "pong_sent_at": {
          "type": "string",
          "format": "date-time",
          "description": "This PONG response timestamp"
        }
      },
      "required": ["sequence", "ping_sent_at", "pong_sent_at"]
    }
  },
  "required": ["type", "message_id", "timestamp", "payload"]
}
