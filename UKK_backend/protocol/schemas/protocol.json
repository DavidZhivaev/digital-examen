{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ukk.school.local/protocol/v1/protocol.json",
  "title": "UKK Protocol Schema",
  "description": "JSON Schema for UKK Protocol messages between agents and relay nodes",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/RegisterMessage" },
    { "$ref": "#/$defs/HeartbeatMessage" },
    { "$ref": "#/$defs/ScreenshotMessage" },
    { "$ref": "#/$defs/TaskResultMessage" },
    { "$ref": "#/$defs/EventMessage" },
    { "$ref": "#/$defs/MetricsMessage" },
    { "$ref": "#/$defs/PongMessage" },
    { "$ref": "#/$defs/TaskMessage" },
    { "$ref": "#/$defs/PolicyUpdateMessage" },
    { "$ref": "#/$defs/PingMessage" },
    { "$ref": "#/$defs/AgentUpdateMessage" },
    { "$ref": "#/$defs/AckMessage" },
    { "$ref": "#/$defs/ErrorMessage" }
  ],
  "$defs": {
    "UUID": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "MessageHeader": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" }
      },
      "required": ["type", "message_id", "timestamp"]
    },
    "AgentStatus": {
      "type": "string",
      "enum": ["ONLINE", "OFFLINE", "ERROR"]
    },
    "TaskStatus": {
      "type": "string",
      "enum": ["OK", "ERROR", "TIMEOUT"]
    },
    "Severity": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    "Priority": {
      "type": "string",
      "enum": ["NORMAL", "HIGH"]
    },
    "RegisterMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "REGISTER" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/RegisterPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "RegisterPayload": {
      "type": "object",
      "properties": {
        "machine_id": { "$ref": "#/$defs/UUID" },
        "building_id": { "type": "string", "minLength": 1 },
        "room_id": { "type": "string", "minLength": 1 },
        "seat_id": { "type": "string" },
        "agent_version": { "type": "string", "minLength": 1 },
        "hw_fingerprint": { "type": "string", "minLength": 64, "maxLength": 64, "pattern": "^[0-9a-fA-F]{64}$" },
        "os_version": { "type": "string" }
      },
      "required": ["machine_id", "building_id", "room_id", "agent_version", "hw_fingerprint"]
    },
    "HeartbeatMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "HEARTBEAT" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/HeartbeatPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "HeartbeatPayload": {
      "type": "object",
      "properties": {
        "cpu_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "ram_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "gpu_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "disk_free_gb": { "type": "number", "minimum": 0 },
        "active_policy": { "type": "string" },
        "status": { "$ref": "#/$defs/AgentStatus" }
      },
      "required": ["cpu_pct", "ram_pct", "status"]
    },
    "ScreenshotMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "SCREENSHOT" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/ScreenshotPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "ScreenshotPayload": {
      "type": "object",
      "properties": {
        "changed": { "type": "boolean" },
        "image_data": { "type": "string", "contentEncoding": "base64" },
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 },
        "phash": { "type": "integer", "minimum": 0 }
      },
      "required": ["changed"],
      "if": { "properties": { "changed": { "const": true } } },
      "then": { "required": ["image_data", "width", "height"] }
    },
    "TaskResultMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "TASK_RESULT" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/TaskResultPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "TaskResultPayload": {
      "type": "object",
      "properties": {
        "task_id": { "$ref": "#/$defs/UUID" },
        "status": { "$ref": "#/$defs/TaskStatus" },
        "output": { "type": "string" },
        "error_code": { "type": "integer" },
        "execution_time_ms": { "type": "integer", "minimum": 0 }
      },
      "required": ["task_id", "status"],
      "if": { "properties": { "status": { "const": "ERROR" } } },
      "then": { "required": ["error_code"] }
    },
    "EventType": {
      "type": "string",
      "enum": ["USB_CONNECTED", "USB_DISCONNECTED", "P2P_DETECTED", "TAMPER_DETECTED", "PROCESS_KILLED", "AGENT_OFFLINE", "POLICY_VIOLATION", "GPU_THRESHOLD"]
    },
    "EventMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "EVENT" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/EventPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "EventPayload": {
      "type": "object",
      "properties": {
        "event_type": { "$ref": "#/$defs/EventType" },
        "severity": { "$ref": "#/$defs/Severity" },
        "details": {
          "oneOf": [
            { "$ref": "#/$defs/UsbEventDetails" },
            { "$ref": "#/$defs/P2pEventDetails" },
            { "$ref": "#/$defs/ProcessEventDetails" },
            { "$ref": "#/$defs/TamperEventDetails" },
            { "type": "string" }
          ]
        }
      },
      "required": ["event_type", "severity", "details"]
    },
    "UsbEventDetails": {
      "type": "object",
      "properties": {
        "vendor_id": { "type": "integer" },
        "product_id": { "type": "integer" },
        "device_class": { "type": "string" },
        "serial": { "type": "string" }
      }
    },
    "P2pEventDetails": {
      "type": "object",
      "properties": {
        "local_ip": { "type": "string", "format": "ipv4" },
        "remote_ip": { "type": "string", "format": "ipv4" },
        "local_port": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "remote_port": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "protocol": { "type": "string", "enum": ["TCP", "UDP"] }
      }
    },
    "ProcessEventDetails": {
      "type": "object",
      "properties": {
        "pid": { "type": "integer" },
        "process_name": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "TamperEventDetails": {
      "type": "object",
      "properties": {
        "expected_hash": { "type": "string" },
        "actual_hash": { "type": "string" },
        "file_path": { "type": "string" }
      }
    },
    "MetricsMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "METRICS" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/MetricsPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "MetricsPayload": {
      "type": "object",
      "properties": {
        "period_start": { "$ref": "#/$defs/Timestamp" },
        "period_end": { "$ref": "#/$defs/Timestamp" },
        "dns_summary": {
          "type": "array",
          "items": { "$ref": "#/$defs/DnsQueryEntry" }
        },
        "app_focus_timeline": {
          "type": "array",
          "items": { "$ref": "#/$defs/AppFocusEntry" }
        },
        "process_list": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProcessInfo" }
        },
        "unique_domains": { "type": "integer", "minimum": 0 },
        "blocked_queries": { "type": "integer", "minimum": 0 }
      },
      "required": ["period_start", "period_end"]
    },
    "DnsQueryEntry": {
      "type": "object",
      "properties": {
        "domain": { "type": "string" },
        "query_count": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "boolean" }
      }
    },
    "AppFocusEntry": {
      "type": "object",
      "properties": {
        "app_name": { "type": "string" },
        "window_title": { "type": "string" },
        "duration_seconds": { "type": "integer", "minimum": 0 },
        "start_time": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "ProcessInfo": {
      "type": "object",
      "properties": {
        "pid": { "type": "integer" },
        "name": { "type": "string" },
        "cmdline": { "type": "string" },
        "cpu_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "memory_mb": { "type": "integer", "minimum": 0 }
      }
    },
    "PongMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "PONG" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/PongPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "PongPayload": {
      "type": "object",
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "ping_sent_at": { "$ref": "#/$defs/Timestamp" },
        "pong_sent_at": { "$ref": "#/$defs/Timestamp" }
      },
      "required": ["sequence", "ping_sent_at", "pong_sent_at"]
    },
    "TaskType": {
      "type": "string",
      "enum": ["SCREENSHOT", "NET_POLICY", "PROCESS_POLICY", "CURSOR_CONTROL", "SCREEN_CONTROL", "TRAFFIC_LIMIT", "USB_POLICY", "AGENT_UPDATE", "GET_METRICS", "SHELL_EXEC"]
    },
    "TaskMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "TASK" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/TaskPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "TaskPayload": {
      "type": "object",
      "properties": {
        "task_id": { "$ref": "#/$defs/UUID" },
        "task_type": { "$ref": "#/$defs/TaskType" },
        "payload": {
          "oneOf": [
            { "$ref": "#/$defs/ScreenshotTaskPayload" },
            { "$ref": "#/$defs/NetPolicyPayload" },
            { "$ref": "#/$defs/ProcessPolicyPayload" },
            { "$ref": "#/$defs/ScreenControlPayload" },
            { "$ref": "#/$defs/UsbPolicyPayload" },
            { "$ref": "#/$defs/TrafficLimitPayload" },
            { "$ref": "#/$defs/ShellExecPayload" }
          ]
        },
        "priority": { "$ref": "#/$defs/Priority" },
        "deadline": { "$ref": "#/$defs/Timestamp" }
      },
      "required": ["task_id", "task_type", "payload"]
    },
    "ScreenshotTaskPayload": {
      "type": "object",
      "properties": {
        "quality": { "type": "integer", "minimum": 1, "maximum": 100 },
        "force_capture": { "type": "boolean" }
      }
    },
    "NetPolicyPayload": {
      "type": "object",
      "properties": {
        "whitelist": { "type": "array", "items": { "type": "string" } },
        "blacklist": { "type": "array", "items": { "type": "string" } },
        "whitelist_only": { "type": "boolean" },
        "bandwidth_limit_kbps": { "type": "integer", "minimum": 0 }
      }
    },
    "ProcessPolicyPayload": {
      "type": "object",
      "properties": {
        "blocked_processes": { "type": "array", "items": { "type": "string" } },
        "gpu_threshold_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "gpu_check_duration_sec": { "type": "integer", "minimum": 0 },
        "auto_kill": { "type": "boolean" }
      }
    },
    "ScreenControlPayload": {
      "type": "object",
      "properties": {
        "action": { "type": "string", "enum": ["BLACKOUT", "RESTORE", "DPMS_OFF", "DPMS_ON"] }
      },
      "required": ["action"]
    },
    "UsbPolicyPayload": {
      "type": "object",
      "properties": {
        "blocked_classes": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 255 } },
        "block_mass_storage": { "type": "boolean" }
      }
    },
    "TrafficLimitPayload": {
      "type": "object",
      "properties": {
        "target_domain": { "type": "string" },
        "limit_kbps": { "type": "integer", "minimum": 0 },
        "remove": { "type": "boolean" }
      }
    },
    "ShellExecPayload": {
      "type": "object",
      "properties": {
        "command": { "type": "string" },
        "timeout_ms": { "type": "integer", "minimum": 0 }
      },
      "required": ["command"]
    },
    "PolicyProfile": {
      "type": "string",
      "enum": ["FREE", "LESSON", "EXAM", "LOCKDOWN"]
    },
    "PolicyUpdateMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "POLICY_UPDATE" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/PolicyUpdatePayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "PolicyUpdatePayload": {
      "type": "object",
      "properties": {
        "policy_id": { "$ref": "#/$defs/UUID" },
        "profile": { "$ref": "#/$defs/PolicyProfile" },
        "rules": { "$ref": "#/$defs/PolicyRules" },
        "effective_from": { "$ref": "#/$defs/Timestamp" },
        "effective_until": { "$ref": "#/$defs/Timestamp" }
      },
      "required": ["policy_id", "profile", "rules", "effective_from"]
    },
    "PolicyRules": {
      "type": "object",
      "properties": {
        "dns_whitelist": { "type": "array", "items": { "type": "string" } },
        "dns_blacklist": { "type": "array", "items": { "type": "string" } },
        "whitelist_only": { "type": "boolean" },
        "bandwidth_limit_kbps": { "type": "integer", "minimum": 0 },
        "blocked_processes": { "type": "array", "items": { "type": "string" } },
        "gpu_threshold_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "auto_kill_violations": { "type": "boolean" },
        "block_mass_storage": { "type": "boolean" },
        "blocked_usb_classes": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 255 } },
        "screenshot_interval_ms": { "type": "integer", "minimum": 0 },
        "screenshot_quality": { "type": "integer", "minimum": 1, "maximum": 100 },
        "detect_p2p": { "type": "boolean" },
        "allow_screen_blackout": { "type": "boolean" }
      }
    },
    "PingMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "PING" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/PingPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "PingPayload": {
      "type": "object",
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "sent_at": { "$ref": "#/$defs/Timestamp" }
      },
      "required": ["sequence", "sent_at"]
    },
    "AgentUpdateMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "AGENT_UPDATE" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/AgentUpdatePayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "AgentUpdatePayload": {
      "type": "object",
      "properties": {
        "new_version": { "type": "string", "minLength": 1 },
        "download_url": { "type": "string", "format": "uri" },
        "sha256_hash": { "type": "string", "minLength": 64, "maxLength": 64, "pattern": "^[0-9a-fA-F]{64}$" },
        "file_size": { "type": "integer", "minimum": 1 },
        "force": { "type": "boolean" },
        "restart_required": { "type": "boolean" }
      },
      "required": ["new_version", "download_url", "sha256_hash", "file_size"]
    },
    "AckMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "ACK" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/AckPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "AckPayload": {
      "type": "object",
      "properties": {
        "acked_message_id": { "$ref": "#/$defs/UUID" }
      },
      "required": ["acked_message_id"]
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["UNKNOWN", "INVALID_MESSAGE", "INVALID_PAYLOAD", "UNSUPPORTED_VERSION", "AUTHENTICATION_FAILED", "TASK_NOT_FOUND", "TASK_EXECUTION_FAILED", "POLICY_INVALID", "RESOURCE_UNAVAILABLE", "RATE_LIMITED", "INTERNAL_ERROR"]
    },
    "ErrorMessage": {
      "type": "object",
      "properties": {
        "type": { "const": "ERROR" },
        "message_id": { "$ref": "#/$defs/UUID" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "$ref": "#/$defs/ErrorPayload" }
      },
      "required": ["type", "message_id", "timestamp", "payload"]
    },
    "ErrorPayload": {
      "type": "object",
      "properties": {
        "reference_id": { "$ref": "#/$defs/UUID" },
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string", "minLength": 1 },
        "details": { "type": "string" }
      },
      "required": ["reference_id", "code", "message"]
    }
  }
}
