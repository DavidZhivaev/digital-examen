{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ukk.school.local/protocol/v1/metrics.json",
  "title": "METRICS Message",
  "description": "Aggregated telemetry and metrics message",
  "type": "object",
  "properties": {
    "type": { "const": "METRICS" },
    "message_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "period_start": {
          "type": "string",
          "format": "date-time",
          "description": "Start of metrics collection period"
        },
        "period_end": {
          "type": "string",
          "format": "date-time",
          "description": "End of metrics collection period"
        },
        "dns_summary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "domain": { "type": "string" },
              "query_count": { "type": "integer", "minimum": 0 },
              "blocked": { "type": "boolean" }
            }
          },
          "description": "DNS query summary"
        },
        "app_focus_timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "app_name": { "type": "string" },
              "window_title": { "type": "string" },
              "duration_seconds": { "type": "integer", "minimum": 0 },
              "start_time": { "type": "string", "format": "date-time" }
            }
          },
          "description": "Application focus timeline"
        },
        "process_list": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pid": { "type": "integer" },
              "name": { "type": "string" },
              "cmdline": { "type": "string" },
              "cpu_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
              "memory_mb": { "type": "integer", "minimum": 0 }
            }
          },
          "description": "Process list snapshot"
        },
        "unique_domains": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of unique domains accessed"
        },
        "blocked_queries": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of blocked DNS queries"
        }
      },
      "required": ["period_start", "period_end"]
    }
  },
  "required": ["type", "message_id", "timestamp", "payload"]
}
