{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ukk.school.local/protocol/v1/policy_update.json",
  "title": "POLICY_UPDATE Message",
  "description": "Policy update message from relay to agent",
  "type": "object",
  "properties": {
    "type": { "const": "POLICY_UPDATE" },
    "message_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "policy_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique policy identifier"
        },
        "profile": {
          "type": "string",
          "enum": ["FREE", "LESSON", "EXAM", "LOCKDOWN"],
          "description": "Policy profile type"
        },
        "rules": {
          "type": "object",
          "properties": {
            "dns_whitelist": {
              "type": "array",
              "items": { "type": "string" },
              "description": "DNS whitelist domains"
            },
            "dns_blacklist": {
              "type": "array",
              "items": { "type": "string" },
              "description": "DNS blacklist domains"
            },
            "whitelist_only": {
              "type": "boolean",
              "default": false,
              "description": "Only allow whitelisted domains"
            },
            "bandwidth_limit_kbps": {
              "type": "integer",
              "minimum": 0,
              "description": "Bandwidth limit in kbps"
            },
            "blocked_processes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "List of blocked process names"
            },
            "gpu_threshold_pct": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "default": 40,
              "description": "GPU usage threshold percentage"
            },
            "auto_kill_violations": {
              "type": "boolean",
              "default": false,
              "description": "Automatically kill policy violating processes"
            },
            "block_mass_storage": {
              "type": "boolean",
              "default": false,
              "description": "Block USB mass storage devices"
            },
            "blocked_usb_classes": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0, "maximum": 255 },
              "description": "Blocked USB device classes"
            },
            "screenshot_interval_ms": {
              "type": "integer",
              "minimum": 0,
              "default": 20000,
              "description": "Screenshot capture interval in milliseconds"
            },
            "screenshot_quality": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 80,
              "description": "Screenshot JPEG quality"
            },
            "detect_p2p": {
              "type": "boolean",
              "default": false,
              "description": "Enable P2P connection detection"
            },
            "allow_screen_blackout": {
              "type": "boolean",
              "default": true,
              "description": "Allow remote screen blackout"
            }
          }
        },
        "effective_from": {
          "type": "string",
          "format": "date-time",
          "description": "Policy effective start time"
        },
        "effective_until": {
          "type": "string",
          "format": "date-time",
          "description": "Policy effective end time (optional)"
        }
      },
      "required": ["policy_id", "profile", "rules", "effective_from"]
    }
  },
  "required": ["type", "message_id", "timestamp", "payload"]
}
