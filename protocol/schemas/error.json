{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ukk.school.local/protocol/v1/error.json",
  "title": "ERROR Message",
  "description": "Error response message",
  "type": "object",
  "properties": {
    "type": { "const": "ERROR" },
    "message_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "reference_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the message that caused the error"
        },
        "code": {
          "type": "string",
          "enum": [
            "UNKNOWN",
            "INVALID_MESSAGE",
            "INVALID_PAYLOAD",
            "UNSUPPORTED_VERSION",
            "AUTHENTICATION_FAILED",
            "TASK_NOT_FOUND",
            "TASK_EXECUTION_FAILED",
            "POLICY_INVALID",
            "RESOURCE_UNAVAILABLE",
            "RATE_LIMITED",
            "INTERNAL_ERROR"
          ],
          "description": "Error code"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable error message"
        },
        "details": {
          "type": "string",
          "description": "Additional error context (JSON)"
        }
      },
      "required": ["reference_id", "code", "message"]
    }
  },
  "required": ["type", "message_id", "timestamp", "payload"]
}
