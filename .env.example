APP_NAME=Школа 1580
DEBUG=true

# Локально: sqlite://db.sqlite3
# Docker:  sqlite:///data/db.sqlite3
DB_URL=sqlite://db.sqlite3
API_PORT=8000

ALGORITHM=RS256
JWT_ISSUER=digital-examen
JWT_AUDIENCE=digital-examen-api

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
MAX_SESSIONS_PER_USER=5

PRIVATE_KEY_PATH=keys/private.pem
PUBLIC_KEY_PATH=keys/public.pem

BCRYPT_ROUNDS=12

RATE_LIMIT_ENABLED=true
RATE_LIMIT_IP_MAX_REQUESTS=10000
RATE_LIMIT_IP_WINDOW_SECONDS=60
RATE_LIMIT_USER_MAX_REQUESTS=3000
RATE_LIMIT_USER_WINDOW_SECONDS=60

LOGIN_RATE_LIMIT_MAX_ATTEMPTS=60
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

USERS_PAGE_SIZE_DEFAULT=20
USERS_PAGE_SIZE_MAX=100

ADMIN_ROLE=4
TEACHER_ROLE=2
OPERATOR_ROLE=3
STUDENT_ROLE=1

FRONTEND_URL=http://localhost:3000
PASSWORD_TOKEN_EXPIRE_HOURS=72

# Gmail — App Password: https://myaccount.google.com/apppasswords
GMAIL_ENABLED=false
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_FROM_NAME=Школа 1580
